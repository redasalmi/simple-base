{
  "name": "solid",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/simple-base-solid.umd.cjs",
  "module": "./dist/simple-base-solid.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/simple-base-solid.js"
