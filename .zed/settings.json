{
  "lsp": {
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt": { "configPath": null }
        }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } }
      ]
    },
    "TypeScript": {
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } }
      ]
    }
  }
}
